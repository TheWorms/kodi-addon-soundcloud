            <visible>!String.IsEmpty(Window.Property(page)) + !String.IsEqual(Window.Property(page),home)</visible>

            <control type="panel" id="400">
                <left>0</left>
                <top>0</top>
                <width>1660</width>
                <height>720</height>
                <onleft>110</onleft>
                <onright>400</onright>
                <onup>400</onup>
                <ondown>400</ondown>
                <itemlayout width="240" height="320">
                <control type="group">
                    <left>20</left>
                    <top>20</top>
                    <width>200</width>
                    <height>280</height>
                    <control type="image">
                        <left>0</left>
                        <top>0</top>
                        <width>200</width>
                        <height>200</height>
                        <texture fallback="cover-placeholder.png">$INFO[ListItem.Art(thumb)]</texture>
                        <aspectratio>scale</aspectratio>
                    </control>
                    <control type="label">
                        <left>0</left>
                        <top>212</top>
                        <width>200</width>
                        <height>26</height>
                        <label>$INFO[ListItem.Label]</label>
                        <font>font13</font>
                        <textcolor>FFFAFAFA</textcolor>
                    </control>
                    <control type="label">
                        <left>0</left>
                        <top>244</top>
                        <width>200</width>
                        <height>22</height>
                        <label>$INFO[ListItem.Artist]</label>
                        <font>font12</font>
                        <textcolor>FFA8A8A8</textcolor>
                    </control>
                </control>
            </itemlayout>
                <focusedlayout width="240" height="320">
                <control type="group">
                    <left>20</left>
                    <top>20</top>
                    <width>200</width>
                    <height>280</height>
                    <animation effect="zoom" start="100" end="106" tween="sine" easing="inout" time="150">Focus</animation>
                    <animation effect="zoom" start="106" end="100" tween="sine" easing="inout" time="150">UnFocus</animation>
                    <control type="image">
                        <left>0</left>
                        <top>0</top>
                        <width>200</width>
                        <height>200</height>
                        <texture fallback="cover-placeholder.png">$INFO[ListItem.Art(thumb)]</texture>
                        <aspectratio>scale</aspectratio>
                    </control>
                    <control type="image">
                        <left>-3</left>
                        <top>-3</top>
                        <width>206</width>
                        <height>206</height>
                        <texture border="10">focus-border.png</texture>
                    </control>
                    <control type="label">
                        <left>0</left>
                        <top>212</top>
                        <width>200</width>
                        <height>26</height>
                        <label>$INFO[ListItem.Label]</label>
                        <font>font13</font>
                        <textcolor>FFFF5500</textcolor>
                    </control>
                    <control type="label">
                        <left>0</left>
                        <top>244</top>
                        <width>200</width>
                        <height>22</height>
                        <label>$INFO[ListItem.Artist]</label>
                        <font>font12</font>
                        <textcolor>FFFAFAFA</textcolor>
                    </control>
                </control>
            </focusedlayout>
                <content/>
            </control>

            <!-- Empty state -->
            <control type="label" id="202">
                <left>0</left>
                <top>200</top>
                <width>1660</width>
                <height>60</height>
                <align>center</align>
                <label>$ADDON[plugin.audio.soundcloud 30157]</label>
                <font>font14</font>
                <textcolor>FF6A6A6A</textcolor>
                <visible>String.IsEqual(Window.Property(page_empty),true)</visible>
            </control>
        </control>

        <!-- ============================================================ -->
        <!-- MINI-PLAYER BAR (bottom)                                     -->
        <!-- ============================================================ -->
        <control type="group" id="500">
            <left>0</left>
            <top>980</top>
            <width>1920</width>
            <height>100</height>
            <visible>!String.IsEqual(Window.Property(miniplayer),off)</visible>

            <!-- Background -->
            <control type="image" id="501">
                <left>0</left>
                <top>0</top>
                <width>1920</width>
                <height>100</height>
                <texture colordiffuse="FF121212">white.png</texture>
            </control>

            <!-- Top divider -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>1920</width>
                <height>1</height>
                <texture colordiffuse="40FFFFFF">white.png</texture>
            </control>

            <!-- Empty state -->
            <control type="group">
                <visible>!Player.HasAudio</visible>
                <control type="label">
                    <left>40</left>
                    <top>30</top>
                    <width>1840</width>
                    <height>40</height>
                    <label>$ADDON[plugin.audio.soundcloud 30121]</label>
                    <font>font13</font>
                    <textcolor>FF6A6A6A</textcolor>
                </control>
            </control>

            <!-- Playing -->
            <control type="group">
                <visible>Player.HasAudio</visible>

                <control type="image" id="510">
                    <left>20</left>
                    <top>18</top>
                    <width>64</width>
                    <height>64</height>
                    <texture fallback="cover-placeholder.png">$INFO[Player.Art(thumb)]</texture>
                    <aspectratio>scale</aspectratio>
                </control>

                <control type="label" id="511">
                    <left>100</left>
                    <top>22</top>
                    <width>520</width>
                    <height>28</height>
                    <label>$INFO[Player.Title]</label>
                    <font>font13</font>
                    <textcolor>FFFAFAFA</textcolor>
                </control>

                <control type="label" id="512">
                    <left>100</left>
                    <top>52</top>
                    <width>520</width>
                    <height>26</height>
                    <label>$INFO[Player.Artist]</label>
                    <font>font12</font>
                    <textcolor>FFA8A8A8</textcolor>
                </control>

                <!-- Controls (visible only when miniplayer=controls) -->
                <control type="group">
                    <visible>String.IsEqual(Window.Property(miniplayer),controls)</visible>

                    <control type="button" id="520">
                        <left>700</left>
                        <top>26</top>
                        <width>48</width>
                        <height>48</height>
                        <label>[B]&lt;[/B]</label>
                        <font>font14</font>
                        <textcolor>FFA8A8A8</textcolor>
                        <focusedcolor>FFFF5500</focusedcolor>
                        <align>center</align>
                        <texturefocus colordiffuse="22FF5500">white.png</texturefocus>
                        <texturenofocus>-</texturenofocus>
                        <onleft>521</onleft>
                        <onright>521</onright>
                        <onup>110</onup>
                    </control>

                    <control type="button" id="521">
                        <left>758</left>
                        <top>20</top>
                        <width>60</width>
                        <height>60</height>
                        <label>[B]$INFO[Player.Paused,&gt;,II][/B]</label>
                        <font>font14</font>
                        <textcolor>FFFAFAFA</textcolor>
                        <focusedcolor>FFFF5500</focusedcolor>
                        <align>center</align>
                        <texturefocus colordiffuse="44FF5500">white.png</texturefocus>
                        <texturenofocus colordiffuse="22FFFFFF">white.png</texturenofocus>
                        <onleft>520</onleft>
                        <onright>522</onright>
                        <onup>110</onup>
                    </control>

                    <control type="button" id="522">
                        <left>828</left>
                        <top>26</top>
                        <width>48</width>
                        <height>48</height>
                        <label>[B]&gt;[/B]</label>
                        <font>font14</font>
                        <textcolor>FFA8A8A8</textcolor>
                        <focusedcolor>FFFF5500</focusedcolor>
                        <align>center</align>
                        <texturefocus colordiffuse="22FF5500">white.png</texturefocus>
                        <texturenofocus>-</texturenofocus>
                        <onleft>521</onleft>
                        <onright>521</onright>
                        <onup>110</onup>
                    </control>
                </control>

                <!-- Time + Progress bar layout depends on mode:
                     - controls mode: time on left, bar in the middle, duration right
                     - compact mode: bar takes most of the width, time + duration small
                -->

                <!-- Time display (controls mode) -->
                <control type="label">
                    <visible>String.IsEqual(Window.Property(miniplayer),controls)</visible>
                    <left>900</left>
                    <top>30</top>
                    <width>120</width>
                    <height>24</height>
                    <label>$INFO[Player.Time]</label>
                    <font>font10</font>
                    <textcolor>FFA8A8A8</textcolor>
                </control>

                <!-- Progress bar (controls mode — narrower) -->
                <control type="progress">
                    <visible>String.IsEqual(Window.Property(miniplayer),controls)</visible>
                    <left>1040</left>
                    <top>44</top>
                    <width>700</width>
                    <height>8</height>
                    <info>Player.Progress</info>
                    <texturebg border="2" colordiffuse="33FFFFFF">white.png</texturebg>
                    <midtexture>orange.png</midtexture>
                </control>

                <!-- Duration (controls mode) -->
                <control type="label">
                    <visible>String.IsEqual(Window.Property(miniplayer),controls)</visible>
                    <left>1760</left>
                    <top>30</top>
                    <width>120</width>
                    <height>24</height>
                    <label>$INFO[Player.Duration]</label>
                    <font>font10</font>
                    <textcolor>FFA8A8A8</textcolor>
                </control>

                <!-- COMPACT MODE: just cover + title + artist + a wide progress bar -->
                <control type="group">
                    <visible>String.IsEqual(Window.Property(miniplayer),compact)</visible>

                    <!-- Time on left (small) -->
                    <control type="label">
                        <left>700</left>
                        <top>40</top>
                        <width>80</width>
                        <height>24</height>
                        <align>right</align>
                        <label>$INFO[Player.Time]</label>
                        <font>font10</font>
                        <textcolor>FFA8A8A8</textcolor>
                    </control>

                    <!-- Wide progress bar -->
                    <control type="progress">
                        <left>800</left>
                        <top>44</top>
                        <width>1000</width>
                        <height>8</height>
                        <info>Player.Progress</info>
                        <texturebg border="2" colordiffuse="33FFFFFF">white.png</texturebg>
                        <midtexture>orange.png</midtexture>
                    </control>

                    <!-- Duration on right -->
                    <control type="label">
                        <left>1820</left>
                        <top>40</top>
                        <width>80</width>
                        <height>24</height>
                        <align>left</align>
                        <label>$INFO[Player.Duration]</label>
                        <font>font10</font>
                        <textcolor>FFA8A8A8</textcolor>
                    </control>
                </control>
            </control>
        </control>

    </controls>
</window>
