<?xml version="1.0" encoding="UTF-8"?>
<!--
  Now Playing — Waveform style (visualizer mode)
  ===============================================

  90 orange bars whose heights are animated continuously by Python
  at ~80ms cadence to simulate an audio visualizer. Lower frequencies
  (left) move slow with medium amplitude, mids vary, highs flicker
  fast. The result LOOKS audio-reactive even though Python has no
  access to the actual audio samples (Kodi's API doesn't expose them).

  Above the bars: a thin progress bar driven by the real Player.Time
  so the user has a true playback position indicator.

  Loaded by NowPlayingDialog when
  Settings > Playback > Fullscreen style = "waveform".
-->
<window type="dialog" id="13101">
    <defaultcontrol>9001</defaultcontrol>
    <coordinates>
        <system>1</system>
    </coordinates>

    <controls>

        <!-- 0. Opaque black mask -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture>black.png</texture>
        </control>

        <!-- 1. Cover art background (Pillow-blurred via Python if available) -->
        <control type="image" id="9100">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture background="true">$INFO[Player.Art(thumb)]</texture>
            <aspectratio>scale</aspectratio>
            <colordiffuse>66FFFFFF</colordiffuse>
            <animation effect="zoom" start="100" end="108" center="auto"
                       time="18000" pulse="true" tween="sine">Conditional</animation>
        </control>

        <!-- 2. Dark gradient overlay at the bottom for text readability. -->
        <control type="image">
            <left>0</left>
            <top>500</top>
            <width>1920</width>
            <height>580</height>
            <texture colordiffuse="BB000000">white.png</texture>
        </control>

        <!-- 3. Track title -->
        <control type="label" id="9001">
            <left>200</left>
            <top>720</top>
            <width>1520</width>
            <height>50</height>
            <align>left</align>
            <font>font14</font>
            <textcolor>FFFFFFFF</textcolor>
            <label>$INFO[Player.Title]</label>
            <animation effect="slide" start="0,30" end="0,0" time="700"
                       tween="cubic" easing="out">WindowOpen</animation>
            <animation effect="fade" start="0" end="100" time="700">WindowOpen</animation>
        </control>

        <!-- 4. Artist (smaller, dimmer) -->
        <control type="label" id="9002">
            <left>200</left>
            <top>780</top>
            <width>1520</width>
            <height>40</height>
            <align>left</align>
            <font>font12</font>
            <textcolor>BBFFFFFF</textcolor>
            <label>$INFO[Player.Artist]</label>
            <animation effect="slide" start="0,30" end="0,0" time="800"
                       delay="80" tween="cubic" easing="out">WindowOpen</animation>
            <animation effect="fade" start="0" end="100" time="800"
                       delay="80">WindowOpen</animation>
        </control>

        <!-- 5. Thin progress bar (real playback position) -->
        <control type="image" id="9150">
            <left>200</left>
            <top>850</top>
            <width>1520</width>
            <height>3</height>
            <texture colordiffuse="33FFFFFF">white.png</texture>
        </control>
        <control type="image" id="9151">
            <left>200</left>
            <top>850</top>
            <width>1</width>
            <height>3</height>
            <texture>orange.png</texture>
        </control>

