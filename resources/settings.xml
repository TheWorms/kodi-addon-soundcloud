<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<!--
    SoundCloud add-on settings — reorganized in 5.5.0 into 3 user-friendly
    sections:
      - Display       (interface, layout, mini-player, home rows)
      - Playback      (audio format, autoplay, shuffle, page size)
      - Account       (OAuth, cache, advanced API knobs)

    Setting IDs are kept for backward compatibility with existing user
    profiles (no resets).
-->
<settings version="1">
    <section id="plugin.audio.soundcloud">

        <!-- ============================================================ -->
        <!-- DISPLAY                                                      -->
        <!-- ============================================================ -->
        <category id="display" label="30200" help="">
            <group id="1" label="30230">
                <setting id="ui.layout" type="integer" label="30133" help="30134">
                    <level>0</level>
                    <default>1</default>
                    <constraints>
                        <options>
                            <option label="30135">0</option>
                            <option label="30136">1</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string"/>
                </setting>
                <setting id="ui.miniplayer" type="integer" label="30137" help="30138">
                    <level>0</level>
                    <default>2</default>
                    <constraints>
                        <options>
                            <option label="30139">0</option>
                            <option label="30181">1</option>
                            <option label="30141">2</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string"/>
                </setting>
            </group>
            <group id="2" label="30170">
                <setting id="row1.type" type="string" label="30171" help="">
                    <level>0</level>
                    <default>likes</default>
                    <constraints>
                        <options>
                            <option label="30172">off</option>
                            <option label="30152">likes</option>
                            <option label="30155">trending</option>
                            <option label="30153">playlists</option>
                            <option label="30154">following</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string"/>
                </setting>
                <setting id="row2.type" type="string" label="30173" help="">
                    <level>0</level>
                    <default>trending</default>
                    <constraints>
                        <options>
                            <option label="30172">off</option>
                            <option label="30152">likes</option>
                            <option label="30155">trending</option>
                            <option label="30153">playlists</option>
                            <option label="30154">following</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string"/>
                </setting>
                <setting id="row3.type" type="string" label="30174" help="">
                    <level>0</level>
                    <default>playlists</default>
                    <constraints>
                        <options>
                            <option label="30172">off</option>
                            <option label="30152">likes</option>
                            <option label="30155">trending</option>
                            <option label="30153">playlists</option>
                            <option label="30154">following</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string"/>
                </setting>
                <setting id="row4.type" type="string" label="30175" help="">
                    <level>0</level>
                    <default>following</default>
                    <constraints>
                        <options>
                            <option label="30172">off</option>
                            <option label="30152">likes</option>
                            <option label="30155">trending</option>
                            <option label="30153">playlists</option>
                            <option label="30154">following</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string"/>
                </setting>
            </group>

            <!-- Widget mode: changes what the plugin's root URL returns,
                 so skin home widgets (Arctic Zephyr, Estuary, etc.) that
                 only support pointing at the addon root can still show
                 a useful flat list instead of the menu. -->
            <group id="3" label="30260">
                <setting id="widget.mode" type="string" label="30261" help="30262">
                    <level>0</level>
                    <default>off</default>
                    <constraints>
                        <options>
                            <option label="30263">off</option>
                            <option label="30264">likes</option>
                            <option label="30265">playlists</option>
                            <option label="30266">following</option>
                            <option label="30267">trending</option>
                            <option label="30268">discover</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string"/>
                </setting>
            </group>
        </category>

        <!-- ============================================================ -->
        <!-- PLAYBACK                                                     -->
        <!-- ============================================================ -->
        <category id="playback" label="30210" help="">
            <group id="1" label="30231">
                <setting id="audio.format" type="integer" label="30232" help="30233">
                    <level>0</level>
                    <default>2</default>
                    <constraints>
                        <options>
                            <option label="30234">0</option>
                            <option label="30235">1</option>
                            <option label="30236">2</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string"/>
                </setting>
                <setting id="ui.autoplay" type="boolean" label="30142" help="30143">
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>
                <setting id="ui.shuffle" type="boolean" label="30144" help="30145">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>
                <setting id="search.items.size" type="string" label="30237" help="30238">
                    <level>0</level>
                    <default>20</default>
                    <constraints>
                        <options>
                            <option>10</option>
                            <option>20</option>
                            <option>30</option>
                            <option>50</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string"/>
                </setting>
            </group>

            <!-- Fullscreen playback overlay: opens a custom WindowXMLDialog
                 on top of the new UI when audio playback starts. The user
                 picks one of 4 visual styles or "off" to disable. -->
            <group id="2" label="32100">
                <setting id="playback.fullscreen_style" type="string" label="32101" help="32114">
                    <level>0</level>
                    <default>off</default>
                    <constraints>
                        <options>
                            <option label="32115">off</option>
                            <option label="32112">cinema</option>
                            <option label="32111">waveform</option>
                            <option label="32113">editorial</option>
                            <option label="32110">vinyl</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string"/>
                </setting>
            </group>
        </category>

        <!-- ============================================================ -->
        <!-- ACCOUNT & ADVANCED                                           -->
        <!-- ============================================================ -->
        <category id="account" label="30220" help="">
            <group id="1" label="30020">
                <setting id="auth.oauth_token" type="string" label="30021" help="30023">
                    <level>0</level>
                    <default/>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string">
                        <heading>30021</heading>
                        <hidden>true</hidden>
                    </control>
                </setting>
                <setting id="auth.test" type="action" label="30240" help="30241">
                    <level>0</level>
                    <data>RunPlugin(plugin://plugin.audio.soundcloud/settings/auth/test/)</data>
                    <control type="button" format="action">
                        <close>false</close>
                    </control>
                </setting>
                <setting id="auth.help" type="action" label="30022" help="">
                    <level>0</level>
                    <data>RunPlugin(plugin://plugin.audio.soundcloud/settings/auth/help/)</data>
                    <control type="button" format="action">
                        <close>false</close>
                    </control>
                </setting>
            </group>
            <group id="2" label="30070">
                <setting id="cache.clear" type="action" label="30071" help="">
                    <level>0</level>
                    <data>RunPlugin(plugin://plugin.audio.soundcloud/settings/cache/clear/)</data>
                    <control type="button" format="action">
                        <close>true</close>
                    </control>
                </setting>
            </group>
            <group id="3" label="30221">
                <setting id="search.history.size" type="string" label="30013" help="">
                    <level>2</level>
                    <default>15</default>
                    <constraints>
                        <options>
                            <option>0</option>
                            <option>5</option>
                            <option>10</option>
                            <option>15</option>
                            <option>20</option>
                            <option>30</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string"/>
                </setting>
                <setting id="apiv2.client_id" type="string" label="30061" help="">
                    <level>2</level>
                    <default/>
                    <constraints>
                        <allowempty>true</allowempty>
                    </constraints>
                    <control type="edit" format="string">
                        <heading>30061</heading>
                    </control>
                </setting>
                <setting id="apiv2.locale" type="integer" label="30062" help="">
                    <level>2</level>
                    <default>0</default>
                    <constraints>
                        <options>
                            <option label="30063">0</option>
                            <option label="30064">1</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string"/>
                </setting>
            </group>
        </category>

    </section>
</settings>
